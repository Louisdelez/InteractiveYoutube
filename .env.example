# Koala TV — environment template.
# Copy to `.env` at repo root: `cp .env.example .env` then fill in.
# `server/config.js` refuses to boot if any `required` var is missing.

# ── Required ──────────────────────────────────────────────────

# YouTube Data API v3 key. Obtain from
# https://console.cloud.google.com/ → Enable YouTube Data API v3.
YOUTUBE_API_KEY=

# Tenor v2 GIF API key. Same Google Cloud console, enable "Tenor API".
TENOR_API_KEY=

# Signing key for session JWTs. Generate with:
#   openssl rand -hex 32
JWT_SECRET=

# Postgres connection string. In Docker Compose the default DB is
# `postgres:interactiveyoutube`, but that password MUST be overridden
# for any deployment that isn't local-only.
DATABASE_URL=postgresql://koalatv:change_me@localhost:5432/koalatv

# ── Optional (defaults in server/config.js) ───────────────────

# Redis connection — defaults to redis://localhost:6379.
REDIS_URL=

# App-server port (HTTP + Socket.IO). Default 4500.
PORT=4500

# Where the browser app runs in dev — used for CORS. Default 4501.
CLIENT_ORIGIN=http://localhost:4501

# NODE_ENV=production flips the auth cookie to `Secure` + stricter CORS.
NODE_ENV=development

# Timezone for the 3am maintenance cron + chat timestamps. Defaults to
# host's `TZ`, falls back to Europe/Paris.
SERVER_TZ=Europe/Paris

# Dead-man-switch ping URL for the daily maintenance worker. Leave
# unset to disable. Example: https://hc-ping.com/<uuid>
HEALTHCHECKS_URL=

# Where the web fallback points users who hit a non-embeddable video.
DESKTOP_DOWNLOAD_URL=https://github.com/Louisdelez/KoalaTV/releases/latest
